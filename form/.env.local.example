# Copiar a .env.local y completar. NUNCA commitear .env.local
# ---------------------------------------------------------------------------

# URL pública del webhook n8n (vía Cloudflare Tunnel)
N8N_WEBHOOK_URL=https://n8n.lga.com.ar/webhook/lga-new-credit-app

# Secret compartido con n8n (al menos 32 chars random).
# Debe coincidir EXACTAMENTE con $env.LGA_WEBHOOK_SECRET en n8n.
# Generar con: openssl rand -hex 32
N8N_WEBHOOK_SECRET=<32+ char random hex>

# Public site URL (para canonicales/SEO)
NEXT_PUBLIC_SITE_URL=https://creditos.domu.com.ar

# WhatsApp de contacto que se muestra al cliente
NEXT_PUBLIC_LGA_WHATSAPP=+5493815551234
