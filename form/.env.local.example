# Copiar a .env.local y completar. NUNCA commitear .env.local
# ---------------------------------------------------------------------------

# Connection string Supabase Postgres (pooler aws-1-sa-east-1, transaction mode)
# Sacar de Supabase Dashboard → Connect → Transaction Pooler → reemplazar [YOUR-PASSWORD] con DB password
DATABASE_URL=postgresql://postgres.<PROJECT-REF>:<DB-PASSWORD>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# Supabase Storage (para uploads de documentos del cliente)
# URL pública y service_role JWT (del Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT-REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role JWT — empieza con eyJ...>

# Public site URL (para canonicales/SEO)
NEXT_PUBLIC_SITE_URL=https://creditos.domuhogar.com

# WhatsApp de contacto que se muestra al cliente
NEXT_PUBLIC_LGA_WHATSAPP=+5493815551234

# WordPress admin dashboard push: lo hace el workflow n8n VPS (no Vercel).
# Las creds WP viven en n8n como credential "WP Admin LGA" (httpBasicAuth).
# El form solo manda el payload completo al notify webhook;
# n8n se encarga de: (a) mensaje Telegram al equipo, (b) crear post en admin.lga-arg.com.
