{%- comment -%}
  ============================================================================
  LGA Credit Button — Cart (cart-drawer + /cart page)
  ----------------------------------------------------------------------------
  Estilo subtle para NO competir con el CTA "Continuar con la compra".

  Comportamiento clave:
   · Se ESCONDE automáticamente cuando el cart está vacío.
   · Se reaparece cuando agregás productos.
   · Si por algún motivo el cart queda vacío al hacer click, muestra mensaje
     INLINE (no alert) debajo del botón.

  CÓMO INSTALAR
  Cart drawer:
   1) Themes → Customize → "Cart drawer" en el selector arriba.
   2) Add block → "Custom Liquid".
   3) Pegar este código.
   4) Drag el bloque DEBAJO del botón "Checkout".
   5) Save.

  Cart page (opcional, por si alguien va directo a /cart):
   1) Themes → Customize → "Cart → Default cart".
   2) Add section → "Custom Liquid".
   3) Pegar este mismo código.
   4) Save.
  ============================================================================
{%- endcomment -%}

<div id="lga-credit-cart" class="lga-credit-wrap" data-context="cart">
  <div class="lga-credit-divider" aria-hidden="true"><span>o también</span></div>

  <button type="button" class="lga-credit-btn" id="lga-credit-cart-trigger">
    <span class="lga-credit-ico" aria-hidden="true">💳</span>
    <span class="lga-credit-label">
      <strong>Pagar este carrito en cuotas con LGA</strong>
      <small>Pago semanal, mensual o diario en efectivo · hasta 24 cuotas · solo Tucumán</small>
    </span>
    <span class="lga-credit-arrow" aria-hidden="true">›</span>
  </button>

  <p class="lga-credit-msg" id="lga-credit-cart-msg" role="status" aria-live="polite"></p>

  <p class="lga-credit-help">
    Proceso aparte del checkout normal. LGA evalúa la solicitud y te contacta por WhatsApp.
  </p>
</div>

<style>
  #lga-credit-cart.lga-credit-wrap { margin: 16px 0 8px; }

  /* Ocultar todo cuando el cart drawer está marcado como vacío por el theme. */
  cart-drawer.is-empty #lga-credit-cart,
  cart-drawer.drawer--empty #lga-credit-cart,
  .template-cart.is-empty #lga-credit-cart,
  body.cart-empty #lga-credit-cart { display: none !important; }

  #lga-credit-cart .lga-credit-divider {
    position: relative; text-align: center;
    margin: 14px 0 12px;
    color: #94a3b8; font-size: 11px;
    text-transform: uppercase; letter-spacing: 1.5px;
  }
  #lga-credit-cart .lga-credit-divider::before,
  #lga-credit-cart .lga-credit-divider::after {
    content: ''; position: absolute; top: 50%;
    width: calc(50% - 50px); height: 1px;
    background: #e5e7eb;
  }
  #lga-credit-cart .lga-credit-divider::before { left: 0; }
  #lga-credit-cart .lga-credit-divider::after  { right: 0; }
  #lga-credit-cart .lga-credit-divider span { padding: 0 10px; position: relative; z-index: 1; }

  #lga-credit-cart .lga-credit-btn {
    display: flex; align-items: center; gap: 12px;
    width: 100%; padding: 13px 14px;
    background: #ffffff; color: #0F766E;
    border: 1.5px solid #0F766E; border-radius: 10px;
    font: inherit; font-weight: 600; font-size: 14.5px;
    cursor: pointer; text-align: left;
    transition: background .15s ease, transform .08s ease, box-shadow .15s ease;
  }
  #lga-credit-cart .lga-credit-btn:hover  { background: #F0FDFA; box-shadow: 0 2px 6px rgba(15,118,110,.08); }
  #lga-credit-cart .lga-credit-btn:active { transform: translateY(1px); }
  #lga-credit-cart .lga-credit-btn:disabled { opacity: .55; cursor: not-allowed; }

  #lga-credit-cart .lga-credit-ico { font-size: 22px; line-height: 1; flex-shrink: 0; }
  #lga-credit-cart .lga-credit-label { display: flex; flex-direction: column; flex: 1; gap: 2px; }
  #lga-credit-cart .lga-credit-label strong { font-weight: 600; font-size: 14.5px; line-height: 1.2; }
  #lga-credit-cart .lga-credit-label small  { font-weight: 400; font-size: 11.5px; color: #64748b; line-height: 1.35; }
  #lga-credit-cart .lga-credit-arrow { font-size: 22px; opacity: .5; flex-shrink: 0; }

  #lga-credit-cart .lga-credit-msg {
    display: none;
    margin: 8px 0 0;
    padding: 8px 10px;
    background: #FEF3C7;
    border: 1px solid #FDE68A;
    border-radius: 8px;
    color: #92400E;
    font-size: 12.5px;
    line-height: 1.4;
    text-align: center;
  }
  #lga-credit-cart .lga-credit-msg.is-visible { display: block; }
  #lga-credit-cart .lga-credit-msg.is-error   { background:#FEE2E2; border-color:#FCA5A5; color:#991B1B; }

  #lga-credit-cart .lga-credit-help {
    font-size: 11px; color: #94a3b8;
    margin: 8px 4px 0; text-align: center; line-height: 1.4;
  }
</style>

<script>
(function () {
  'use strict';
  var FORM_BASE = 'https://creditos.domuhogar.com/aplicar';
  var SHOP      = {{ shop.permanent_domain | json }};
  var btn       = document.getElementById('lga-credit-cart-trigger');
  var msgEl     = document.getElementById('lga-credit-cart-msg');
  var wrap      = document.getElementById('lga-credit-cart');
  if (!btn || !wrap) return;

  // --- UTM helpers ----------------------------------------------------------
  function readUtmFromUrl() {
    var p = new URLSearchParams(location.search), u = {};
    ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach(function(k){
      var v = p.get(k); if (v) u[k] = v;
    });
    return u;
  }
  function readUtmCookie() {
    var m = document.cookie.match(/(?:^|;\s*)lga_utm=([^;]+)/);
    if (!m) return {};
    try { return JSON.parse(decodeURIComponent(m[1])); } catch(e){ return {}; }
  }
  var utm = Object.assign({}, readUtmCookie(), readUtmFromUrl());

  // --- Mensajes inline ------------------------------------------------------
  function showMsg(text, isError) {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.classList.add('is-visible');
    msgEl.classList.toggle('is-error', !!isError);
  }
  function hideMsg() {
    if (!msgEl) return;
    msgEl.classList.remove('is-visible', 'is-error');
    msgEl.textContent = '';
  }

  // --- Visibility según cart count (defensa extra al CSS) -------------------
  function syncVisibility(count) {
    if (typeof count !== 'number') return;
    wrap.style.display = (count > 0) ? '' : 'none';
  }

  // Cart sync inicial + listeners de updates del theme
  function refreshCart() {
    fetch('/cart.js', { credentials: 'same-origin', headers: {'Accept':'application/json'} })
      .then(function(r){ return r.json(); })
      .then(function(c){ syncVisibility(c && c.items ? c.items.length : 0); })
      .catch(function(){});
  }
  refreshCart();

  // Dawn-based themes disparan estos eventos al cambiar el cart
  ['cart:update','cart:refresh','cart:added','cart:removed','cart-items:updated','cart-drawer:updated']
    .forEach(function(ev){ document.addEventListener(ev, refreshCart); });

  // Listener directo en cart-drawer custom element (Dawn)
  var drawer = document.querySelector('cart-drawer');
  if (drawer && 'MutationObserver' in window) {
    new MutationObserver(refreshCart).observe(drawer, { attributes: true, attributeFilter: ['class'] });
  }

  // --- Click handler --------------------------------------------------------
  btn.addEventListener('click', function () {
    if (btn.disabled) return;
    btn.disabled = true;
    hideMsg();

    fetch('/cart.js', { credentials: 'same-origin', headers: {'Accept':'application/json'} })
      .then(function(r){ return r.json(); })
      .then(function(cart){
        if (!cart || !cart.items || !cart.items.length) {
          showMsg('Tu carrito está vacío — agregá productos y volvé a tocar acá.', true);
          syncVisibility(0);
          btn.disabled = false;
          return;
        }

        var primary = cart.items[0];
        var params = new URLSearchParams({
          shop: SHOP,
          source: cart.items.length === 1 ? 'cart_single' : 'cart_multi',
          product_id: String(primary.product_id),
          variant_id: String(primary.variant_id),
          title: primary.product_title || '',
          handle: primary.handle || '',
          price: String(primary.price),
          qty: String(primary.quantity),
          cart_total: String(cart.total_price),
          cart_token: cart.token || '',
          cart_items: String(cart.items.length),
          ref: location.href
        });
        if (cart.items.length > 1) {
          params.set('cart_summary', cart.items.map(function(i){
            return i.product_title + ' x' + i.quantity;
          }).join(' | ').slice(0, 240));
        }
        Object.keys(utm).forEach(function(k){ params.set(k, utm[k]); });

        try { if (window.gtag) window.gtag('event','lga_credit_click',{source:'cart',items:cart.items.length}); } catch(e){}
        try { if (window.fbq)  window.fbq('trackCustom','LGACreditClick',{source:'cart',items:cart.items.length}); } catch(e){}

        var labelStrong = btn.querySelector('.lga-credit-label strong');
        if (labelStrong) labelStrong.textContent = 'Abriendo formulario…';
        location.href = FORM_BASE + '?' + params.toString();
      })
      .catch(function(){
        showMsg('No pudimos leer el carrito. Refrescá la página e intentá de nuevo.', true);
        btn.disabled = false;
      });
  });
})();
</script>
