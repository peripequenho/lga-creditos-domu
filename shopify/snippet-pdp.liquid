{%- comment -%}
  ============================================================================
  LGA Credit Button — PDP (versión secundaria / outline)
  ----------------------------------------------------------------------------
  Estilo intencionalmente subtle para NO competir con el CTA principal
  "Comprar ahora / Agregar al carrito". Queda como opción alternativa.

  CÓMO INSTALAR
  1) Online Store → Themes → Customize.
  2) Template selector → "Products → Default product".
  3) Sección "Product information" → Add block → "Custom Liquid".
  4) Posicionar DEBAJO del "Buy buttons".
  5) Pegar este código en el campo "Liquid". Save.

  EXCLUIR PRODUCTOS PUNTUALES
  Agregar tag 'no-lga' al producto en Shopify admin.
  ============================================================================
{%- endcomment -%}

{% unless product.tags contains 'no-lga' %}
<div id="lga-credit-pdp" class="lga-credit-wrap" data-context="pdp">
  <div class="lga-credit-divider" aria-hidden="true"><span>o también</span></div>

  <button type="button" class="lga-credit-btn" id="lga-credit-trigger">
    <span class="lga-credit-ico" aria-hidden="true">💳</span>
    <span class="lga-credit-label">
      <strong>Pagá en cuotas con crédito LGA</strong>
      <small>Pago semanal, mensual o diario en efectivo · hasta 24 cuotas · solo Tucumán</small>
    </span>
    <span class="lga-credit-arrow" aria-hidden="true">›</span>
  </button>

  <p class="lga-credit-help">
    Es un proceso aparte del pago directo: LGA evalúa la solicitud y te contacta por WhatsApp.
    No se cobra nada acá.
  </p>
</div>

<style>
  #lga-credit-pdp.lga-credit-wrap { margin: 18px 0; }

  #lga-credit-pdp .lga-credit-divider {
    position: relative; text-align: center;
    margin: 16px 0 14px;
    color: #94a3b8; font-size: 11px;
    text-transform: uppercase; letter-spacing: 1.5px;
  }
  #lga-credit-pdp .lga-credit-divider::before,
  #lga-credit-pdp .lga-credit-divider::after {
    content: ''; position: absolute; top: 50%;
    width: calc(50% - 50px); height: 1px;
    background: #e5e7eb;
  }
  #lga-credit-pdp .lga-credit-divider::before { left: 0; }
  #lga-credit-pdp .lga-credit-divider::after  { right: 0; }
  #lga-credit-pdp .lga-credit-divider span { padding: 0 10px; background: transparent; position: relative; z-index: 1; }

  #lga-credit-pdp .lga-credit-btn {
    display: flex; align-items: center; gap: 12px;
    width: 100%; padding: 14px 16px;
    background: #ffffff; color: #0F766E;
    border: 1.5px solid #0F766E; border-radius: 10px;
    font: inherit; font-weight: 600; font-size: 15px;
    cursor: pointer; text-align: left;
    transition: background .15s ease, transform .08s ease, box-shadow .15s ease;
  }
  #lga-credit-pdp .lga-credit-btn:hover  { background: #F0FDFA; box-shadow: 0 2px 6px rgba(15,118,110,.08); }
  #lga-credit-pdp .lga-credit-btn:active { transform: translateY(1px); }
  #lga-credit-pdp .lga-credit-btn:disabled { opacity: .55; cursor: not-allowed; }

  #lga-credit-pdp .lga-credit-ico { font-size: 22px; line-height: 1; flex-shrink: 0; }
  #lga-credit-pdp .lga-credit-label { display: flex; flex-direction: column; flex: 1; gap: 2px; }
  #lga-credit-pdp .lga-credit-label strong { font-weight: 600; font-size: 15px; line-height: 1.2; }
  #lga-credit-pdp .lga-credit-label small  { font-weight: 400; font-size: 11.5px; color: #64748b; line-height: 1.35; }
  #lga-credit-pdp .lga-credit-arrow { font-size: 22px; opacity: .5; flex-shrink: 0; }

  #lga-credit-pdp .lga-credit-help {
    font-size: 11px; color: #94a3b8;
    margin: 8px 4px 0; text-align: center; line-height: 1.4;
  }
</style>

<script>
(function () {
  'use strict';
  var FORM_BASE = 'https://creditos.domuhogar.com/aplicar';
  var SHOP      = {{ shop.permanent_domain | json }};
  var btn       = document.getElementById('lga-credit-trigger');
  if (!btn) return;

  // --- Helpers UTM (URL → cookie persistente 30 días) -----------------------
  function readUtmFromUrl() {
    var p = new URLSearchParams(location.search);
    var u = {};
    ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach(function(k){
      var v = p.get(k); if (v) u[k] = v;
    });
    return u;
  }
  function readUtmCookie() {
    var m = document.cookie.match(/(?:^|;\s*)lga_utm=([^;]+)/);
    if (!m) return {};
    try { return JSON.parse(decodeURIComponent(m[1])); } catch(e){ return {}; }
  }
  function writeUtmCookie(u) {
    if (!u || !Object.keys(u).length) return;
    var v = encodeURIComponent(JSON.stringify(u));
    var exp = new Date(Date.now() + 30*24*60*60*1000).toUTCString();
    document.cookie = 'lga_utm='+v+'; expires='+exp+'; path=/; SameSite=Lax';
  }
  var freshUtm = readUtmFromUrl();
  if (Object.keys(freshUtm).length) writeUtmCookie(freshUtm);
  var utm = Object.assign({}, readUtmCookie(), freshUtm);

  // --- Producto y variante seleccionada -------------------------------------
  var product = {{ product | json }};

  function selectedVariantId() {
    var input = document.querySelector('form[action*="/cart/add"] [name="id"]');
    if (input && input.value) return input.value;
    if (product && product.variants) {
      var av = product.variants.find(function(v){ return v.available; });
      return av ? av.id : (product.variants[0] && product.variants[0].id);
    }
    return null;
  }

  function selectedQty() {
    // El theme de Domu tiene quantity FUERA del form `/cart/add`.
    // Probamos varios selectores en orden de especificidad.
    var candidates = [
      'form[action*="/cart/add"] input[name="quantity"]:not([type="hidden"])',
      'input[name="quantity"]:not([type="hidden"])',
      'select[name="quantity"]',
      'quantity-input input[name="quantity"]',
      '.quantity__input',
      'input.quantity__input',
    ];
    for (var i = 0; i < candidates.length; i++) {
      var el = document.querySelector(candidates[i]);
      if (el && el.value) {
        var n = parseInt(el.value, 10);
        if (Number.isFinite(n) && n >= 1) return n;
      }
    }
    return 1;
  }

  btn.addEventListener('click', function () {
    var variantId = selectedVariantId();
    if (!product || !variantId) {
      alert('Seleccioná una variante antes de continuar.');
      return;
    }
    var variant = (product.variants || []).find(function(v){ return String(v.id) === String(variantId); })
                || product.variants[0];

    var qty = selectedQty();

    var unitCents = variant.price || product.price || 0; // centavos
    var params = new URLSearchParams({
      shop: SHOP,
      source: 'pdp',
      product_id: String(product.id),
      variant_id: String(variantId),
      title: product.title || '',
      handle: product.handle || '',
      price: String(Math.round(unitCents)),
      qty: String(qty),
      cart_total: String(Math.round(unitCents * qty)),
      ref: location.href
    });
    Object.keys(utm).forEach(function(k){ params.set(k, utm[k]); });

    try { if (window.gtag) window.gtag('event','lga_credit_click',{source:'pdp',product_id:product.id}); } catch(e){}
    try { if (window.fbq)  window.fbq('trackCustom','LGACreditClick',{source:'pdp',product_id:product.id}); } catch(e){}

    btn.disabled = true;
    var labelStrong = btn.querySelector('.lga-credit-label strong');
    if (labelStrong) labelStrong.textContent = 'Abriendo formulario…';
    location.href = FORM_BASE + '?' + params.toString();
  });
})();
</script>
{% endunless %}
