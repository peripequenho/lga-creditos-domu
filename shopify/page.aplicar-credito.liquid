  .lga-form-wrap .lga-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #065f46; padding: 1.5rem; border-radius: 0.5rem; }
  .lga-form-wrap .lga-success h2 { margin-top: 0; color: #065f46; }
  .lga-form-wrap .lga-success code { background: #d1fae5; padding: 0.2rem 0.4rem; border-radius: 0.25rem; font-family: ui-monospace, monospace; font-weight: 600; }
