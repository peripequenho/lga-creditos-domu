<div class="lga-form-wrap">
  <h1>Aplicar a crédito LGA</h1>
  <p class="lga-subtitle">Te contactamos por WhatsApp en las próximas 24 hs hábiles para coordinar la visita.</p>

  <div id="lga-order-summary" class="lga-order-summary" style="display:none">
    <div class="lga-row"><span>Producto</span><strong id="lga-os-title">—</strong></div>
    <div class="lga-row"><span>Cantidad</span><strong id="lga-os-qty">—</strong></div>
    <div class="lga-row"><span>Total carrito</span><strong id="lga-os-total">—</strong></div>
  </div>

  <div id="lga-error" class="lga-error" style="display:none"></div>

  <div id="lga-success" class="lga-success" style="display:none">
    <h2>¡Solicitud recibida!</h2>
    <p>Tu código de aplicación es <code id="lga-success-code">—</code>.</p>
    <p>Te vamos a contactar por WhatsApp en las próximas 24 hs hábiles para coordinar la visita y completar la documentación.</p>
    <p style="margin-bottom:0"><a href="https://domuhogar.com/" style="color:#0f766e;font-weight:500">← Volver a la tienda</a></p>
  </div>

  <form id="lga-form" novalidate>
    <!-- Honeypot anti-bot -->
    <div class="lga-honeypot" aria-hidden="true">
      <label>No completar este campo<input type="text" name="hp_website" tabindex="-1" autocomplete="off"></label>
    </div>

    <fieldset>
      <legend>Identidad</legend>
      <div class="lga-grid">
        <label><span>Nombre *</span><input name="first_name" required maxlength="60"></label>
        <label><span>Apellido *</span><input name="last_name" required maxlength="60"></label>
        <label><span>DNI * (solo números, 7-9 dígitos)</span><input name="dni" required inputmode="numeric" pattern="\d{7,9}" maxlength="9"></label>
        <label><span>Fecha de nacimiento *</span><input name="birth_date" type="date" required></label>
        <label><span>Teléfono * (con código de área, sin 15)</span><input name="phone" required inputmode="tel" placeholder="3815551234"></label>
        <label><span>Email</span><input name="email" type="email" maxlength="120"></label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Domicilio</legend>
      <div class="lga-grid">
        <label class="lga-full"><span>Dirección *</span><input name="address_line" required maxlength="120" placeholder="Av. Mate de Luna 1200, Dpto B"></label>
        <label><span>Localidad *</span><input name="locality" required maxlength="60"></label>
        <label><span>Provincia *</span><input name="province" required maxlength="60" value="Tucumán"></label>
        <label><span>Código postal *</span><input name="postal_code" required maxlength="8" placeholder="T4000"></label>
        <label>
          <span>Vivienda *</span>
          <select name="housing_status" required>
            <option value="">— Elegir —</option>
            <option value="owned">Propia</option>
            <option value="rented">Alquilada</option>
            <option value="family">Familiar / cedida</option>
            <option value="other">Otra</option>
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Ocupación e ingresos</legend>
      <div class="lga-grid">
        <label>
          <span>Ocupación *</span>
          <select name="occupation" required>
            <option value="">— Elegir —</option>
            <option value="employed_registered">Empleado registrado</option>
            <option value="self_employed_registered">Monotributista / Autónomo</option>
            <option value="unregistered">Trabajo informal</option>
            <option value="retired">Jubilado / Pensionado</option>
            <option value="homemaker">Ama de casa</option>
            <option value="student">Estudiante</option>
            <option value="informal">Changas / cuenta propia</option>
            <option value="other">Otra</option>
          </select>
        </label>
        <label><span>Detalle de ocupación</span><input name="occupation_detail" maxlength="120" placeholder="Ej: vendedor en comercio local"></label>
        <label class="lga-full"><span>Ingreso declarado (ARS / mes)</span><input name="declared_income_ars" type="number" min="0" step="1000"></label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Crédito solicitado</legend>
      <div class="lga-grid-3">
        <label><span>Monto (ARS) *</span><input name="requested_amount_ars" type="number" required min="1000" step="1000"></label>
        <label>
          <span>Frecuencia *</span>
          <select name="payment_frequency" required>
            <option value="monthly">Mensual</option>
            <option value="weekly">Semanal</option>
            <option value="daily">Diaria</option>
          </select>
        </label>
        <label><span>Cantidad de cuotas *</span><input name="requested_installments" type="number" required min="1" max="36" value="6"></label>
      </div>
      <div class="lga-grid" style="margin-top:1rem">
        <label class="lga-full"><span>Cuota estimada (opcional, ARS)</span><input name="estimated_installment_ars" type="number" min="0" step="100"></label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Garante (opcional)</legend>
      <div class="lga-grid">
        <label><span>Nombre completo</span><input name="guarantor_name" maxlength="120"></label>
        <label><span>Teléfono</span><input name="guarantor_phone" inputmode="tel"></label>
        <label class="lga-full"><span>Relación</span><input name="guarantor_relation" maxlength="60" placeholder="Familiar, conocido, etc."></label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Consentimientos</legend>
      <label style="display:flex;align-items:flex-start;font-size:0.875rem;line-height:1.5">
        <input type="checkbox" name="marketing_consent" value="1" style="margin-top:0.2rem">
        <span style="margin-left:0;font-size:0.85rem;color:#52525b">Acepto que LGA me contacte por WhatsApp/email con información de mi solicitud y novedades.</span>
      </label>
    </fieldset>

    <div class="lga-actions">
      <button type="submit" class="lga-submit" id="lga-btn">Enviar solicitud</button>
    </div>
  </form>
</div>

<script>
(function() {
  'use strict';

  // ─── Endpoint del webhook n8n (cambiar si el host es distinto) ──────────
  var WEBHOOK_URL = 'https://n8n.lga-arg.com/webhook/lga-shopify-form';

  // ─── Helpers ────────────────────────────────────────────────────────────
  function uuid() {
    if (crypto && crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }
  function money(n) {
    var v = Math.round(Number(n) || 0);
    return '$' + v.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  }
  function qs(k) {
    var p = new URLSearchParams(window.location.search);
    return p.get(k) || '';
  }

  // ─── Pre-fill del resumen de pedido desde query string ──────────────────
  var prodTitle = qs('title') || qs('product_title');
  var price     = qs('price') || qs('unit_price_ars') || qs('cart_total');
  var qty       = qs('qty') || qs('quantity') || '1';
  var cartTotal = qs('cart_total') || qs('cart_total_ars');

  if (prodTitle || price || cartTotal) {
    document.getElementById('lga-order-summary').style.display = 'block';
    document.getElementById('lga-os-title').textContent = prodTitle || '—';
    document.getElementById('lga-os-qty').textContent = qty || '1';
    document.getElementById('lga-os-total').textContent = cartTotal ? money(cartTotal) : (price ? money(price) : '—');
    // Pre-fill el monto pretendido con el total del carrito si vino
    var montoInput = document.querySelector('input[name="requested_amount_ars"]');
    if (montoInput && !montoInput.value && (cartTotal || price)) {
      montoInput.value = Math.round(Number(cartTotal || price) || 0);
    }
  }

  // ─── Submit handler ─────────────────────────────────────────────────────
  var form = document.getElementById('lga-form');
  var btn = document.getElementById('lga-btn');
  var errorBox = document.getElementById('lga-error');
  var successBox = document.getElementById('lga-success');

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.style.display = 'block';
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function hideError() {
    errorBox.style.display = 'none';
    errorBox.textContent = '';
  }

  form.addEventListener('submit', function(ev) {
    ev.preventDefault();
    hideError();

    // Honeypot anti-bot
    var hp = form.querySelector('[name="hp_website"]');
    if (hp && hp.value) {
      // No mostramos nada, simulamos éxito silencioso
      successBox.style.display = 'block';
      form.style.display = 'none';
      return;
    }

    // Validar nativo
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Recolectar valores
    var fd = new FormData(form);
    var payload = {};
    fd.forEach(function(v, k) {
      if (k === 'hp_website') return; // honeypot, no mandar
      payload[k] = typeof v === 'string' ? v.trim() : v;
    });

    // Convertir checkbox marketing
    payload.marketing_consent = !!fd.get('marketing_consent');

    // Numéricos
    ['requested_amount_ars','requested_installments','declared_income_ars',
     'estimated_installment_ars','quantity','unit_price_ars','cart_total_ars',
     'product_id','variant_id'].forEach(function(k) {
      if (payload[k] !== undefined && payload[k] !== '') {
        var n = Number(payload[k]);
        if (Number.isFinite(n)) payload[k] = n;
      }
    });

    // Idempotency + query string + UTM
    payload.idempotency_key = uuid();
    payload.shop          = 'domu';
    payload.source        = qs('source') || 'shopify_pdp';
    payload.product_id    = payload.product_id    || qs('product_id')    || '';
    payload.variant_id    = payload.variant_id    || qs('variant_id')    || '';
    payload.product_title = payload.product_title || qs('product_title') || qs('title') || '';
    payload.product_handle= payload.product_handle|| qs('product_handle')|| qs('handle') || '';
    payload.unit_price_ars= payload.unit_price_ars|| Number(qs('unit_price_ars') || qs('price') || 0);
    payload.quantity      = payload.quantity      || Number(qs('quantity') || qs('qty') || 1);
    payload.cart_token    = payload.cart_token    || qs('cart_token')    || '';
    payload.cart_total_ars= payload.cart_total_ars|| Number(qs('cart_total_ars') || qs('cart_total') || 0);
    payload.cart_summary  = qs('cart_summary')    || '';
    payload.utm_source    = qs('utm_source');
    payload.utm_medium    = qs('utm_medium');
    payload.utm_campaign  = qs('utm_campaign');
    payload.utm_content   = qs('utm_content');
    payload.utm_term      = qs('utm_term');
    payload.referrer_url  = document.referrer || '';
    payload.landing_url   = window.location.href;

    // Estado submit
    btn.disabled = true;
    btn.textContent = 'Enviando…';

    fetch(WEBHOOK_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    .then(function(res) {
      return res.json().catch(function() { return { ok: res.ok }; }).then(function(data) {
        return { status: res.status, ok: res.ok, data: data };
      });
    })
    .then(function(r) {
      if (!r.ok) {
        throw new Error((r.data && (r.data.error || r.data.message)) || ('HTTP ' + r.status));
      }
      // Success
      form.style.display = 'none';
      document.getElementById('lga-order-summary').style.display = 'none';
      successBox.style.display = 'block';
      var code = r.data && r.data.application_code ? r.data.application_code : '(pendiente)';
      document.getElementById('lga-success-code').textContent = code;
      successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    })
    .catch(function(err) {
      showError('No pudimos procesar tu solicitud. Reintentá en 1 minuto. (' + (err && err.message ? err.message : 'error') + ')');
      btn.disabled = false;
      btn.textContent = 'Enviar solicitud';
    });
  });
})();
</script>
